# Server
NODE_ENV=development
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info

# Backing services (match docker-compose.yml)
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgres://janus:janus@localhost:5432/janus

# Upstream providers (used from Phase 1 onward) — never commit real keys
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
# Optional model-aware routing: comma-separated models this provider serves.
# Leave blank/unset = wildcard (serves any model). Set per provider to route a
# model to a specific upstream (and exercise fallback) without taking one offline.
# GROQ_MODELS=llama-3.1-8b-instant,llama-3.3-70b-versatile
# Optional local fallback provider (uncomment to enable):
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODELS=llama3.2

# Exact-match response cache (Phase 4)
CACHE_ENABLED=true
CACHE_TTL_SECONDS=300

# Upstream reliability (Phase 5)
UPSTREAM_TIMEOUT_MS=30000
UPSTREAM_MAX_RETRIES=2
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_COOLDOWN_MS=15000

# Semantic cache (Phase 7, opt-in — needs pgvector + an embeddings endpoint)
SEMANTIC_CACHE_ENABLED=false
SEMANTIC_CACHE_THRESHOLD=0.95
# EMBEDDING_BASE_URL=http://localhost:11434/v1   # e.g. local Ollama, or https://api.openai.com/v1
# EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
