# Server
NODE_ENV=development
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info

# Backing services (match docker-compose.yml)
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgres://janus:janus@localhost:5432/janus

# Upstream providers (used from Phase 1 onward) — never commit real keys
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Exact-match response cache (Phase 4)
CACHE_ENABLED=true
CACHE_TTL_SECONDS=300

# Upstream reliability (Phase 5)
UPSTREAM_TIMEOUT_MS=30000
UPSTREAM_MAX_RETRIES=2
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_COOLDOWN_MS=15000
