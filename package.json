{
  "name": "janus",
  "version": "1.0.0",
  "description": "Janus — a self-hostable, OpenAI-compatible LLM API gateway",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "node --env-file-if-exists=.env --watch src/server.js",
    "start": "node --env-file-if-exists=.env src/server.js",
    "migrate": "node --env-file-if-exists=.env src/db/migrate.js",
    "mint-key": "node --env-file-if-exists=.env src/db/mintKey.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "keywords": [
    "llm",
    "gateway",
    "fastify",
    "openai"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "fastify": "^5.2.0",
    "fastify-plugin": "^5.0.1",
    "ioredis": "^5.4.2",
    "pg": "^8.13.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "autocannon": "^8.0.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "vitest": "^2.1.8"
  }
}
